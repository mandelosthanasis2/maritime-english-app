# Example environment variables for the backend.
# Copy to `.env` and fill in real values. DO NOT commit real secrets.

# ---- AI text (content) generation provider ----------------------------------
# Which provider generates Hermes lesson content (generate_lessons, enrich,
# backfill teaching, auto-categorize, email scenarios). Roleplay and email
# feedback always use Claude and are NOT affected by this setting.
#   deepseek -> DeepSeek primary, Claude fallback (default)
#   claude   -> Claude only (exactly the previous behaviour)
AI_PROVIDER=deepseek

# DeepSeek is reached through its Anthropic-compatible endpoint, so only the
# key + model + base URL change — the request/response shape is identical.
# If DEEPSEEK_API_KEY is missing, generation silently falls back to Claude.
DEEPSEEK_API_KEY=
# Explicit model name (NOT the deepseek-chat/deepseek-reasoner aliases, which
# retire 2026-07-24). Default is their top model; set to deepseek-v4-flash to
# try the cheaper one by changing only this variable.
DEEPSEEK_MODEL=deepseek-v4-pro
# DeepSeek's Anthropic-compatible base URL (rarely needs changing).
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# Disable thinking for generation so a reasoning model doesn't silently bill
# reasoning tokens. Set to "false" only if you want thinking on.
DEEPSEEK_DISABLE_THINKING=true

# Anthropic / Claude — used for the Claude-only calls (roleplay, email
# feedback) and as the fallback provider for content generation.
ANTHROPIC_API_KEY=

# ---- Other services -----------------------------------------------------------
# Azure Speech, the database, etc. have their own variables and are unrelated
# to the AI text provider switch above.
